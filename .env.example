# DeepSeek API credentials
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# Feishu credentials
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Feishu 事件订阅安全校验（飞书开放平台 → 事件与回调 → 加密策略）
# 强烈建议至少配置 Verification Token；配置 Encrypt Key 后自动启用签名校验与事件解密
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# 网页调试台 /api/* 端点的访问令牌。不配置则调试 API 整体禁用（生产环境建议留空）
DEBUG_API_TOKEN=

# 图片票据 OCR 用的多模态模型 Key（配合 config/model.yaml 的 vision.enabled=true）
# 阿里云百炼(qwen-vl)可直接用 DASHSCOPE_API_KEY
VISION_API_KEY=

# Optional overrides
# FEISHU_API_BASE=https://open.feishu.cn
# DATABASE_PATH=data/conversations.db
# SOUL_PATH=config/soul.md
# CONFIG_DIR=config
